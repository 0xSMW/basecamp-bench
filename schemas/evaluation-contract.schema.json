{
  "$schema":"https://json-schema.org/draft/2020-12/schema",
  "$id":"https://raw.githubusercontent.com/0xSMW/basecamp-bench/main/schemas/evaluation-contract.schema.json",
  "title":"Evaluation contract",
  "type":"object",
  "additionalProperties":false,
  "required":["schema_version","contract_version","track","description","dimensions","overall_policy"],
  "properties":{
    "schema_version":{"const":"1.0"},
    "contract_version":{"type":"string","minLength":1},
    "track":{"enum":["fe","be"]},
    "description":{"type":"string","minLength":1},
    "dimensions":{"type":"array","minItems":1,"uniqueItems":true,"items":{"$ref":"#/$defs/dimension"}},
    "overall_policy":{"type":"object","additionalProperties":false,"required":["method","precision","missing"],"properties":{"method":{"const":"weighted_sum"},"precision":{"type":"integer","minimum":0,"maximum":12},"missing":{"const":"invalidate"}}}
  },
  "$defs":{
    "id":{"type":"string","pattern":"^[a-z0-9][a-z0-9._-]{0,63}$"},
    "dimension":{"type":"object","additionalProperties":false,"required":["id","label","weight","anchors"],"properties":{"id":{"$ref":"#/$defs/id"},"label":{"type":"string","minLength":1},"weight":{"type":"number","exclusiveMinimum":0,"maximum":1},"anchors":{"type":"object","additionalProperties":false,"required":["0","5","10"],"properties":{"0":{"type":"string","minLength":1},"5":{"type":"string","minLength":1},"10":{"type":"string","minLength":1}}}}}
  }
}

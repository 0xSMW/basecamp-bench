{
  "$schema":"https://json-schema.org/draft/2020-12/schema",
  "$id":"https://raw.githubusercontent.com/0xSMW/basecamp-bench/main/schemas/judge-result.schema.json",
  "title":"Judge result",
  "type":"object",
  "additionalProperties":false,
  "required":["schema_version","track","submission_id","contract_sha256","judge_id","dimensions","summary"],
  "properties":{
    "schema_version":{"const":"1.0"},
    "track":{"enum":["fe","be"]},
    "submission_id":{"type":"string","pattern":"^[a-z0-9][a-z0-9._-]{0,63}$"},
    "contract_sha256":{"type":"string","pattern":"^[a-f0-9]{64}$"},
    "judge_id":{"type":"string","pattern":"^[a-z0-9][a-z0-9._-]{0,63}$"},
    "dimensions":{"type":"object","minProperties":1,"propertyNames":{"type":"string","pattern":"^[a-z0-9][a-z0-9._-]{0,63}$"},"additionalProperties":{"$ref":"#/$defs/dimension"}},
    "summary":{"type":"string","minLength":1}
  },
  "$defs":{"dimension":{"type":"object","additionalProperties":false,"required":["score","notes","evidence"],"properties":{"score":{"type":"number","minimum":0,"maximum":10},"notes":{"type":"string","minLength":1},"evidence":{"type":"array","minItems":1,"items":{"type":"string","minLength":1}}}}}
}

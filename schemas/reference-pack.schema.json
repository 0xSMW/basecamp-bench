{
  "$schema":"https://json-schema.org/draft/2020-12/schema",
  "$id":"https://raw.githubusercontent.com/0xSMW/basecamp-bench/main/schemas/reference-pack.schema.json",
  "title":"Reference pack manifest",
  "type":"object",
  "additionalProperties":false,
  "required":["schema_version","pack_id","pack_version","distributable","assets"],
  "properties":{
    "schema_version":{"const":"1.0"},"pack_id":{"type":"string","pattern":"^[a-z0-9][a-z0-9._-]{0,63}$"},"pack_version":{"type":"string","minLength":1},"distributable":{"type":"boolean"},
    "assets":{"type":"array","uniqueItems":true,"items":{"type":"object","additionalProperties":false,"required":["path","sha256","owner","source","license","modifications","distributable"],"properties":{"path":{"type":"string","minLength":1,"pattern":"^(?!/)(?![A-Za-z]:)(?!.*\\\\)(?!.*//)(?!.*(?:^|/)\\.{1,2}(?:/|$))[^\\u0000-\\u001f]+$"},"sha256":{"type":"string","pattern":"^[a-f0-9]{64}$"},"owner":{"type":"string","minLength":1},"source":{"type":"string","minLength":1},"license":{"type":"string","minLength":1},"modifications":{"type":"string"},"distributable":{"type":"boolean"}}}}
  }
}
